# DATABASE_URL — PostgreSQL connection string dari Neon
# Contoh: postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=""

# ADMIN_PASSWORD — Password untuk akses dashboard analytics lama (/dashboard)
# Login di https://domain-anda.com/login (single user, env-based)
ADMIN_PASSWORD=""

# AUTH_SECRET — Random string untuk signing session cookie
# Generate: openssl rand -base64 32
AUTH_SECRET=""

# APP_URL — URL produksi (untuk canonical, og:url, dsb)
APP_URL="https://masjidrayapuritelukjambe.com"

# UPLOADTHING_TOKEN — Token UploadThing untuk featured image artikel
# Daftar di https://uploadthing.com dan ambil token dari dashboard
UPLOADTHING_TOKEN=""
UPLOADTHING_SECRET=""
UPLOADTHING_APP_ID=""
